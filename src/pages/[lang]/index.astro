---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ArticlesList from '../../components/ArticlesList.astro';
import CertificatesList from '../../components/CertificatesList.astro';
import CTAButton from '../../components/CTAButton.astro';
import TeachingCard from '../../components/TeachingCard';
import SocialLinks from '../../components/SocialLinks';
import { getCertificates } from '../../config/certificates';
import { getPublicationGroups } from '../../config/publications';
import {
	educationItems,
	experienceItems,
	profileFacts,
} from '../../i18n/cv-content';
import { languages, type Lang } from '../../i18n/ui';
import { hashNavPath, useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
	return languages.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
const lang = langParam as Lang;
const t = useTranslations(lang);
const publicationGroups = getPublicationGroups();
const certificates = getCertificates(lang);
---

<BaseLayout lang={lang}>
	<section id="bosh" class="scroll-mt-24 mb-section lg:scroll-mt-28">
		<div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:gap-12">
			<div class="min-w-0">
				<div class="flex items-start gap-4 lg:block">
					<div class="min-w-0 flex-1">
						<p class="mb-2 text-sm font-semibold tracking-widest text-accent uppercase lg:mb-3">
							{t('hero.greeting')}
						</p>
						<h1
							class="font-sans text-2xl leading-tight text-balance text-ink sm:text-3xl md:text-4xl lg:text-6xl dark:text-paper"
						>
							{t('profile.name')}
						</h1>
						<p class="mt-1 font-sans text-sm text-ink-muted sm:mt-2 sm:text-lg md:text-xl lg:text-2xl dark:text-paper/70">
							{t('profile.role')}
						</p>
					</div>

					<img
						src="/images/portrait.jpg"
						alt={t('profile.name')}
						width="112"
						height="140"
						class="aspect-[4/5] w-24 shrink-0 rounded-xl border border-border/60 object-cover object-top shadow-lg sm:w-28 lg:hidden dark:border-border-dark/60"
						loading="eager"
						decoding="async"
					/>
				</div>

				<p class="prose-width mt-6 max-w-none text-lg leading-relaxed text-ink-muted lg:mt-8 lg:max-w-prose dark:text-paper/75">
					{t('hero.intro')}
				</p>

				<div class="mt-8 flex flex-wrap gap-4 lg:mt-10">
					<CTAButton href={hashNavPath(lang, 'maqolalar')}>
						{t('nav.maqolalar')}
					</CTAButton>
					<CTAButton href={hashNavPath(lang, 'cv')} variant="secondary">
						{t('hero.cta.cv')}
					</CTAButton>
				</div>
			</div>

			<div class="hidden shrink-0 lg:block">
				<img
					src="/images/portrait.jpg"
					alt={t('profile.name')}
					width="352"
					height="440"
					class="aspect-[4/5] w-full rounded-2xl border border-border/60 object-cover object-top shadow-lg dark:border-border-dark/60"
					loading="eager"
					decoding="async"
				/>
			</div>
		</div>
	</section>

	<Section id="bio" title={t('hero.facts.title')}>
		<dl class="grid gap-4 sm:grid-cols-2">
			{
				profileFacts.map(({ labelKey, valueKey }) => (
					<div class="rounded-lg border border-border bg-surface p-4 dark:border-border-dark dark:bg-surface-dark">
						<dt class="text-sm font-medium text-ink-muted dark:text-paper/60">{t(labelKey)}</dt>
						<dd class="mt-1 font-sans text-ink dark:text-paper">{t(valueKey)}</dd>
					</div>
				))
			}
		</dl>
	</Section>

	<Section id="darslar" title={t('hero.teaching.title')}>
		<div class="grid gap-6 md:grid-cols-3">
			<TeachingCard
				icon="classics"
				title={t('hero.teaching.classics')}
				description={t('hero.teaching.classics.desc')}
			/>
			<TeachingCard
				icon="poetry"
				title={t('hero.teaching.poetry')}
				description={t('hero.teaching.poetry.desc')}
			/>
			<TeachingCard
				icon="culture"
				title={t('hero.teaching.culture')}
				description={t('hero.teaching.culture.desc')}
			/>
		</div>
	</Section>

	<Section id="yutuqlar" title={t('hero.experience.title')}>
		<ol class="relative space-y-6 border-l-2 border-accent/30 pl-6 dark:border-accent/40">
			{
				experienceItems.map(({ periodKey, roleKey, placeKey }) => (
					<li class="relative">
						<span
							class="absolute -left-[1.6rem] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-paper dark:bg-paper-dark"
							aria-hidden="true"
						></span>
						<p class="text-sm font-semibold text-accent">{t(periodKey)}</p>
						<h3 class="mt-1 font-sans text-lg text-ink dark:text-paper">{t(roleKey)}</h3>
						<p class="mt-1 text-sm leading-relaxed text-ink-muted dark:text-paper/70">
							{t(placeKey)}
						</p>
					</li>
				))
			}
		</ol>
	</Section>

	<Section id="maqolalar" title={t('hero.articles.title')}>
		<ArticlesList
			groups={publicationGroups}
			viewLabel={t('articles.view')}
			emptyLabel={t('articles.empty')}
		/>
	</Section>

	<Section id="cv" title={t('hero.education.title')}>
		<ul class="space-y-4">
			{
				educationItems.map(({ yearKey, degreeKey, placeKey, documentHref }) => {
					const content = (
						<>
							<span class="shrink-0 font-semibold text-accent">{t(yearKey)}</span>
							<div class="min-w-0 flex-1">
								<h3 class="font-sans text-lg text-ink dark:text-paper">{t(degreeKey)}</h3>
								<p class="mt-1 text-sm text-ink-muted dark:text-paper/70">{t(placeKey)}</p>
							</div>
							{documentHref && (
								<svg
									class="mt-1 h-4 w-4 shrink-0 text-accent sm:mt-1.5"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
									/>
								</svg>
							)}
						</>
					);

					return documentHref ? (
						<li>
							<a
								href={documentHref}
								target="_blank"
								rel="noopener noreferrer"
								class="card-skill card-skill-link flex flex-col gap-2 sm:flex-row sm:items-start sm:gap-6"
								aria-label={`${t(degreeKey)} — ${t('articles.view')}`}
							>
								{content}
							</a>
						</li>
					) : (
						<li class="card-skill flex flex-col gap-2 sm:flex-row sm:items-start sm:gap-6">
							{content}
						</li>
					);
				})
			}
		</ul>
		<div class="mt-8">
			<CTAButton href="/cv.pdf" download>
				{t('hero.cta.cv')}
			</CTAButton>
		</div>
	</Section>

	<Section id="sertifikatlar" title={t('nav.sertifikatlar')}>
		<p class="prose-width mb-6 text-lg leading-relaxed text-ink-muted dark:text-paper/75">
			{t('section.sertifikatlar.text')}
		</p>
		<CertificatesList
			certificates={certificates}
			viewLabel={t('articles.view')}
			emptyLabel={t('certificates.empty')}
		/>
	</Section>

	<Section id="aloqa" title={t('nav.aloqa')}>
		<p class="prose-width mb-6 text-lg leading-relaxed text-ink-muted dark:text-paper/75">
			{t('section.aloqa.text')}
		</p>
		<SocialLinks
			client:visible
			variant="default"
			class="flex items-center gap-3"
			labels={{
				'social.telegram': t('social.telegram'),
				'social.instagram': t('social.instagram'),
				'social.phone': t('social.phone'),
				'social.email': t('social.email'),
			}}
		/>
	</Section>
</BaseLayout>
