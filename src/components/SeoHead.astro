---
import { languages, type Lang } from '../i18n/ui';
import {
	OG_IMAGE_HEIGHT,
	OG_IMAGE_PATH,
	OG_IMAGE_WIDTH,
	PERSON_FULL_NAME,
	absoluteUrl,
	buildJsonLd,
	ogLocaleMap,
	type SeoContent,
} from '../config/seo';

interface Props {
	lang: Lang;
	pageTitle: string;
	pageDescription: string;
	keywords: string;
	canonicalUrl: string;
	canonicalPath: string;
	siteOrigin: string;
	profileName: string;
	role: string;
}

const {
	lang,
	pageTitle,
	pageDescription,
	keywords,
	canonicalUrl,
	canonicalPath,
	siteOrigin,
	profileName,
	role,
} = Astro.props;

const ogImageUrl = absoluteUrl(OG_IMAGE_PATH, siteOrigin);
const ogLocale = ogLocaleMap[lang];
const alternateLocales = languages.filter((code) => code !== lang).map((code) => ogLocaleMap[code]);

const seoContent: SeoContent = {
	title: pageTitle,
	description: pageDescription,
	keywords,
	profileName,
	role,
};

const jsonLd = buildJsonLd(lang, siteOrigin, canonicalUrl, seoContent);
---

<meta name="description" content={pageDescription} />
<meta name="keywords" content={keywords} />
<meta name="author" content={PERSON_FULL_NAME} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta name="theme-color" content="#54b689" />

<link rel="canonical" href={canonicalUrl} />
<link rel="sitemap" type="application/xml" href={absoluteUrl('/sitemap-index.xml', siteOrigin)} />

<title>{pageTitle}</title>

<meta property="og:type" content="profile" />
<meta property="og:site_name" content={profileName} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={ogLocale} />
{alternateLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
<meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
<meta property="og:image:alt" content={profileName} />
<meta property="profile:first_name" content="Oydinniso" />
<meta property="profile:last_name" content="Nasirdinova" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={profileName} />

{
	languages.map((altLang) => {
		const segments = canonicalPath.split('/').filter(Boolean);
		if (segments.length > 0) segments[0] = altLang;
		const altPath = segments.length ? `/${segments.join('/')}/` : `/${altLang}/`;
		return (
			<link
				rel="alternate"
				hreflang={altLang}
				href={absoluteUrl(altPath, siteOrigin)}
			/>
		);
	})
}
<link rel="alternate" hreflang="x-default" href={absoluteUrl('/uz/', siteOrigin)} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
