---
import type { CertificateFile } from '../config/certificates';

interface Props {
	certificates: CertificateFile[];
	viewLabel: string;
	emptyLabel: string;
}

const { certificates, viewLabel, emptyLabel } = Astro.props;
---

{
	certificates.length === 0 ? (
		<p class="prose-width text-lg leading-relaxed text-ink-muted dark:text-paper/75">
			{emptyLabel}
		</p>
	) : (
		<ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
			{
				certificates.map((file) => (
					<li>
						<a
							href={file.url}
							target="_blank"
							rel="noopener noreferrer"
							class="card-skill card-skill-link flex h-full flex-col"
							aria-label={`${file.title} — ${viewLabel}`}
						>
							<div class="icon-skill mb-4 flex h-10 w-10 items-center justify-center rounded-full">
								<svg
									class="h-5 w-5"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.627 48.627 0 0 1 12 20.904a48.627 48.627 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.57 50.57 0 0 0-2.658-.813A59.905 59.905 0 0 1 12 3.493a59.902 59.902 0 0 1 10.399 5.84c-.908.217-1.804.5-2.658.814m-15.482 0A50.697 50.697 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
									/>
								</svg>
							</div>
							<h3 class="font-sans text-lg leading-snug text-ink dark:text-paper">
								{file.title}
							</h3>
							<span class="mt-auto inline-flex items-center gap-1.5 pt-4 text-sm font-semibold text-accent">
								{viewLabel}
								<svg
									class="h-4 w-4"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
									/>
								</svg>
							</span>
						</a>
					</li>
				))
			}
		</ul>
	)
}
